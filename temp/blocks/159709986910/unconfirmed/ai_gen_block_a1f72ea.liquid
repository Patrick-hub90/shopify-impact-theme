{% doc %}
  @prompt
    Section pour lister les etapes dutilisation dune pommade, je veux une section pour les differents etapes dutilisation dun epommade
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ointment-steps-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-ointment-steps__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-ointment-steps__title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    margin: 0 0 {{ block.settings.header_spacing | divided_by: 2 }}px;
    font-weight: 700;
  }

  .ai-ointment-steps__subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subtitle_size }}px;
    margin: 0;
    opacity: 0.9;
  }

  .ai-ointment-steps__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap_between_steps }}px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .ai-ointment-steps__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.step_background }};
    border-radius: {{ block.settings.step_border_radius }}px;
    border: {{ block.settings.step_border_width }}px solid {{ block.settings.step_border_color }};
    transition: transform 0.2s ease;
  }

  .ai-ointment-steps__item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-ointment-steps__number-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-ointment-steps__number-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.number_size }}px;
    height: {{ block.settings.number_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.number_background }};
    color: {{ block.settings.number_text_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: {{ block.settings.number_font_size }}px;
  }

  .ai-ointment-steps__step-title-{{ ai_gen_id }} {
    color: {{ block.settings.step_title_color }};
    font-size: {{ block.settings.step_title_size }}px;
    font-weight: 600;
    margin: 0;
    flex: 1;
  }

  .ai-ointment-steps__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .ai-ointment-steps__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
    fill: none;
    stroke-width: 2;
  }

  .ai-ointment-steps__description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.description_size }}px;
    margin: 0;
    line-height: 1.6;
  }

  @media screen and (max-width: 989px) {
    .ai-ointment-steps__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-ointment-steps-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-ointment-steps__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-ointment-steps__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-ointment-steps__number-{{ ai_gen_id }} {
      width: {{ block.settings.number_size | times: 0.85 }}px;
      height: {{ block.settings.number_size | times: 0.85 }}px;
      font-size: {{ block.settings.number_font_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<ointment-steps-{{ ai_gen_id }} class="ai-ointment-steps-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank or block.settings.subtitle != blank %}
    <div class="ai-ointment-steps__header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-ointment-steps__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <div class="ai-ointment-steps__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
      {% endif %}
    </div>
  {% endif %}

  <ol class="ai-ointment-steps__grid-{{ ai_gen_id }}">
    {% for i in (1..8) %}
      {% liquid
        assign step_title_key = 'step_' | append: i | append: '_title'
        assign step_desc_key = 'step_' | append: i | append: '_description'
        assign step_icon_key = 'step_' | append: i | append: '_icon'
        assign step_title = block.settings[step_title_key]
        assign step_desc = block.settings[step_desc_key]
        assign step_icon = block.settings[step_icon_key]
      %}

      {% if step_title != blank or step_desc != blank %}
        <li class="ai-ointment-steps__item-{{ ai_gen_id }}">
          <div class="ai-ointment-steps__number-wrapper-{{ ai_gen_id }}">
            <div class="ai-ointment-steps__number-{{ ai_gen_id }}">{{ i }}</div>
            {% if step_title != blank %}
              <h3 class="ai-ointment-steps__step-title-{{ ai_gen_id }}">{{ step_title }}</h3>
            {% endif %}
            {% if block.settings.show_icons %}
              <div class="ai-ointment-steps__icon-{{ ai_gen_id }}">
                {% if step_icon == 'hand' %}
                  <svg viewBox="0 0 24 24"><path d="M9 11V6a1 1 0 0 1 2 0v5M9 11a1 1 0 1 1 2 0M9 11h2m0 0v5a1 1 0 0 0 1 1h1a1 1 0 0 0 1-1v-1m0-9v5a1 1 0 0 0 1 1h1a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1h-1a1 1 0 0 0-1 1v0a1 1 0 0 1-1 1h0M7 15a1 1 0 0 1-1-1V9a1 1 0 0 1 2 0v5a1 1 0 0 1-1 1z"/></svg>
                {% elsif step_icon == 'droplet' %}
                  <svg viewBox="0 0 24 24"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
                {% elsif step_icon == 'clock' %}
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                {% elsif step_icon == 'check' %}
                  <svg viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                {% elsif step_icon == 'rotate' %}
                  <svg viewBox="0 0 24 24"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/></svg>
                {% elsif step_icon == 'spray' %}
                  <svg viewBox="0 0 24 24"><path d="M7 13v8a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-8M7 13h10M7 13l1-5h8l1 5M12 3v2M16 5l-1 1M8 5l1 1"/></svg>
                {% elsif step_icon == 'sun' %}
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
                {% else %}
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
                {% endif %}
              </div>
            {% endif %}
          </div>
          {% if step_desc != blank %}
            <div class="ai-ointment-steps__description-{{ ai_gen_id }}">{{ step_desc }}</div>
          {% endif %}
        </li>
      {% endif %}
    {% endfor %}
  </ol>
</ointment-steps-{{ ai_gen_id }}>

<script>
  (function() {
    class OintmentSteps{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('ointment-steps-{{ ai_gen_id }}', OintmentSteps{{ ai_gen_id }});
  })();
</script>

