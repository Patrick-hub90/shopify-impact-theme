<style>
  .custom-tabs-section {
    --primary-color: {{ section.settings.primary_color }};
    --secondary-color: {{ section.settings.secondary_color }};
    --text-color: {{ section.settings.text_color }};
    --active-tab-color: {{ section.settings.active_tab_color }};
    --border-radius: {{ section.settings.border_radius }}px;
    --tab-spacing: {{ section.settings.tab_spacing }}px;
    --tab-padding: {{ section.settings.tab_padding }}px;
    font-family: 'Helvetica Neue', Arial, sans-serif;
    padding: 80px 0;
    background: {{ section.settings.background_gradient | default: section.settings.background_color }};
    color: var(--text-color);
  }
  
  .custom-tabs-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  
  .section-header {
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: 60px;
  }
  
  .section-header h2 {
    font-size: 36px;
    font-weight: 700;
    margin: 0 0 15px;
    color: var(--primary-color);
    position: relative;
    display: inline-block;
  }
  
  .section-header h2::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 4px;
    background: var(--secondary-color);
    border-radius: 2px;
  }
  
  .section-header p {
    font-size: 18px;
    max-width: 700px;
    margin: 20px auto 0;
    color: var(--text-color);
    opacity: 0.8;
    line-height: 1.6;
  }
  
  .tabs-container {
    background: white;
    border-radius: var(--border-radius);
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    overflow: hidden;
  }
  
  .tabs-header {
    display: flex;
    background: #f8f9fa;
    border-bottom: 1px solid #e9ecef;
    padding: 0 var(--tab-spacing);
    overflow-x: auto;
    scrollbar-width: none;
  }
  
  .tabs-header::-webkit-scrollbar {
    display: none;
  }
  
  .tab-btn {
    padding: calc(var(--tab-padding) + 5px) var(--tab-padding);
    font-size: 16px;
    font-weight: 600;
    color: var(--text-color);
    background: transparent;
    border: none;
    border-bottom: 3px solid transparent;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  
  .tab-btn:after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 3px;
    background: var(--active-tab-color);
    transition: width 0.3s ease;
  }
  
  .tab-btn.is-active {
    color: var(--primary-color);
  }
  
  .tab-btn.is-active:after {
    width: 100%;
  }
  
  .tab-btn:hover:not(.is-active) {
    color: var(--primary-color);
    background: rgba(0,0,0,0.02);
  }
  
  .tab-icon {
    font-size: 20px;
    display: flex;
    align-items: center;
  }
  
  .tabs-content {
    padding: 40px;
  }
  
  .tab-content {
    display: none;
    animation: fadeIn 0.5s ease;
  }
  
  .tab-content.is-active {
    display: block;
  }
  
  .tab-content-inner {
    display: flex;
    gap: 40px;
  }
  
  .tab-content-text {
    flex: 1;
  }
  
  .tab-content-image {
    flex: 0 0 45%;
    border-radius: calc(var(--border-radius) - 10px);
    overflow: hidden;
    box-shadow: 0 15px 30px rgba(0,0,0,0.1);
  }
  
  .tab-content-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  
  .tab-content h3 {
    font-size: 24px;
    margin-top: 0;
    margin-bottom: 20px;
    color: var(--primary-color);
  }
  
  .tab-content ul {
    padding-left: 20px;
    margin-bottom: 25px;
  }
  
  .tab-content li {
    margin-bottom: 12px;
    line-height: 1.6;
    position: relative;
    padding-left: 25px;
  }
  
  .tab-content li:before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--secondary-color);
    font-weight: bold;
  }
  
  .tab-content strong {
    color: var(--primary-color);
  }
  
  .feature-highlight {
    background: linear-gradient(to right, rgba(255,255,255,0.1), rgba(255,255,255,0.4));
    border-left: 4px solid var(--secondary-color);
    padding: 20px;
    border-radius: 8px;
    margin: 30px 0;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  @media (max-width: 900px) {
    .tab-content-inner {
      flex-direction: column;
    }
    
    .tab-content-image {
      order: -1;
    }
    
    .tabs-content {
      padding: 30px 20px;
    }
    
    .section-header h2 {
      font-size: 28px;
    }
    
    .custom-tabs-section {
      padding: 50px 0;
    }
  }
  
  @media (max-width: 600px) {
    .tabs-header {
      gap: 5px;
      padding: 0 10px;
    }
    
    .tab-btn {
      padding: 15px;
      font-size: 14px;
    }
    
    .tab-icon {
      font-size: 16px;
    }
    
    .section-header h2 {
      font-size: 24px;
    }
  }
</style>

<section class="custom-tabs-section" id="shopify-section-{{ section.id }}">
  <div class="custom-tabs-container">
    <div class="section-header">
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
    
    <div class="tabs-container">
      <div class="tabs-header">
        {% for block in section.blocks %}
          <button class="tab-btn {% if forloop.first %}is-active{% endif %}" data-id="{{ forloop.index }}">
            {% if block.settings.tab_icon != 'none' %}
              <span class="tab-icon">{{ block.settings.tab_icon }}</span>
            {% endif %}
            {{ block.settings.tab_title }}
          </button>
        {% endfor %}
      </div>
      
      <div class="tabs-content">
        {% for block in section.blocks %}
          <div class="tab-content {% if forloop.first %}is-active{% endif %}" data-id="{{ forloop.index }}">
            <div class="tab-content-inner">
              <div class="tab-content-text">
                {{ block.settings.tab_content }}
                
                {% if block.settings.feature_text != blank %}
                  <div class="feature-highlight">
                    {{ block.settings.feature_text }}
                  </div>
                {% endif %}
              </div>
              
              {% if block.settings.tab_image %}
                <div class="tab-content-image">
                  <img src="{{ block.settings.tab_image | img_url: '800x' }}" 
                       alt="{{ block.settings.tab_title }}" 
                       loading="lazy">
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const tabButtons = document.querySelectorAll('.tab-btn');
  
  tabButtons.forEach(button => {
    button.addEventListener('click', function() {
      // Remove active class from all buttons
      tabButtons.forEach(btn => btn.classList.remove('is-active'));
      
      // Add active class to clicked button
      this.classList.add('is-active');
      
      const tabId = this.getAttribute('data-id');
      const tabContents = document.querySelectorAll('.tab-content');
      
      // Hide all tab contents
      tabContents.forEach(content => content.classList.remove('is-active'));
      
      // Show selected tab content
      document.querySelector(`.tab-content[data-id="${tabId}"]`).classList.add('is-active');
    });
  });
  
  // Add subtle hover effect
  tabButtons.forEach(button => {
    button.addEventListener('mouseenter', function() {
      if (!this.classList.contains('is-active')) {
        this.style.transform = 'translateY(-3px)';
      }
    });
    
    button.addEventListener('mouseleave', function() {
      this.style.transform = '';
    });
  });
});
</script>

