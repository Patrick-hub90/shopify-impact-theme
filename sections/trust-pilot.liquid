{% style %}
.product-reviews-section {
  background-color: #ffffff;
  padding: 40px 0;
}

.trustpilot-verified {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 16px 0;
}

.product-reviews-slider-wrapper {
  position: relative;
  max-width: 1200px;
  margin: 0 auto;
}

.product-reviews-slider {
  padding: 20px;
}

.product-reviews-item {
  background: #f9f9f9;
  border-radius: 8px;
  padding: 20px;
  height: auto;
  box-sizing: border-box;
}

.product-reviews-stars {
  display: flex;
  gap: 2px;
  margin-bottom: 10px;
}

.product-reviews-stars img {
  width: 20px;
  height: 20px;
}

.product-reviews-verified {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-bottom: 10px;
}

.product-reviews-verified svg {
  width: 16px;
  height: 16px;
}

.product-reviews-verified-text {
  font-size: 13px;
  color: #333;
}

.product-reviews-title {
  font-size: 18px;
  font-weight: bold;
  margin: 10px 0;
  color: #000;
}

.product-reviews-text {
  font-size: 14px;
  line-height: 1.5;
  color: #555;
  margin-bottom: 15px;
}

.product-reviews-publication {
  display: flex;
  gap: 8px;
}

.product-reviews-author {
  font-size: 13px;
  font-weight: bold;
  color: #000;
}

.product-reviews-time {
  font-size: 13px;
  color: #888;
}

.product-reviews-bottom-text {
  text-align: center;
  margin-top: 20px;
  font-size: 14px;
  color: #555;
}

.product-reviews-btn-prev,
.product-reviews-btn-next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 40px;
  height: 40px;
  background: #fff;
  border: 1px solid #ddd;
  border-radius: 50%;
  cursor: pointer;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-reviews-btn-prev {
  left: -20px;
}

.product-reviews-btn-next {
  right: -20px;
}

@media (max-width: 768px) {
  .product-reviews-btn-prev,
  .product-reviews-btn-next {
    display: none;
  }
}
{% endstyle %}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<div class="product-reviews-section">
  <div class="trustpilot-verified">
    <img src="https://cdn.trustpilot.net/brand-assets/4.0.0/logo-black.svg" alt="Trustpilot" style="height: 20px;">
    <div>
      <span style="font-size: 15px; font-weight: 600; color: #000;">Vérifié par Trustpilot</span>
      <span style="font-size: 13px; color: #888;">Basé sur plus de 2000 avis clients vérifiés</span>
    </div>
  </div>

  <div class="product-reviews-slider-wrapper">
    <button class="product-reviews-btn-prev" aria-label="Diapositive précédente">
      <span class="animate-icon">←</span>
    </button>
    
    <div class="product-reviews-slider swiper">
      <div class="swiper-wrapper">
        <!-- Avis 1 -->
        <div class="product-reviews-item swiper-slide">
          <div class="product-reviews-review">
            <div class="product-reviews-stars">
              {% for i in (1..5) %}
                <img src="{{ 'single-star-5.png' | asset_url }}" alt="" loading="lazy">
              {% endfor %}
            </div>
            <div class="product-reviews-verified">
              <div class="product-reviews-verified-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" id="verified">
                  <path fill="#000" fill-rule="evenodd" d="M1 12C1 5.92487 5.92487 1 12 1C18.0751 1 23 5.92487 23 12C23 18.0751 18.0751 23 12 23C5.92487 23 1 18.0751 1 12ZM11.2071 16.2071L18.2071 9.20711L16.7929 7.79289L10.5 14.0858L7.20711 10.7929L5.79289 12.2071L9.79289 16.2071C9.98043 16.3946 10.2348 16.5 10.5 16.5C10.7652 16.5 11.0196 16.3946 11.2071 16.2071Z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <p class="product-reviews-verified-text">Vérifié</p>
            </div>
          </div>
          <h2 class="product-reviews-title">8 semaines d'expérience</h2>
          <div class="product-reviews-text">
            <p>Je n'aurais jamais cru que quoi que ce soit puisse réduire l'apparence de la cellulite sur mes cuisses, mais Vaovac m'a prouvé le contraire. Après seulement 8 semaines d'utilisation régulière, ma peau est visiblement plus lisse et la cellulite a visiblement diminué.</p>
          </div>
          <div class="product-reviews-publication">
            <p class="product-reviews-author">Vérone,</p>
            <p class="product-reviews-time">01/02/2025</p>
          </div>
        </div>
        
        <!-- Ajoutez ici les autres avis de la même manière -->
        <!-- ... (copiez la structure pour chaque avis) ... -->
        
      </div>
    </div>
    
    <button class="product-reviews-btn-next" aria-label="Diapositive suivante">
      <span class="animate-icon">→</span>
    </button>
  </div>
  
  <div class="product-reviews-bottom-text">
    <p>Note : <strong>4,8</strong> /5 selon 2028 avis. Nos avis 5 étoiles sont affichés.</p>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const swiper = new Swiper('.product-reviews-slider', {
    slidesPerView: 1,
    spaceBetween: 16,
    navigation: {
      nextEl: '.product-reviews-btn-next',
      prevEl: '.product-reviews-btn-prev',
    },
    breakpoints: {
      640: {
        slidesPerView: 2,
      },
      1024: {
        slidesPerView: 3,
      }
    }
  });
});
</script>