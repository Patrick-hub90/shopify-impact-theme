<cart-drawer {% if request.design_mode %}handle-section-events{% endif %} class="cart-drawer drawer drawer--lg" id="cart-drawer">
  {%- if cart.item_count == 0 -%}
    <!-- Contenu du panier vide inchangé -->
  {%- else -%}
    <div>
      <div class="cart-drawer__top">
        <div class="h-stack items-center justify-between">
          <div class="h-stack grow gap-2 sm:gap-2.5">
            <p class="h5">{{- 'cart.general.title' | t -}}</p>
            <cart-count class="count-bubble count-bubble--md">{{ cart.item_count }}</cart-count>
          </div>

          <button type="button" is="close-button" class="drawer__close-icon">
            <span class="sr-only">{{ 'general.accessibility.close' | t }}</span>
            {%- render 'icon' with 'close' -%}
          </button>
        </div>

        {%- if settings.cart_show_free_shipping_threshold -%}
          {%- render 'free-shipping-bar' -%}
        {%- endif -%}
      </div>

      <div class="v-stack gap-6 sm:gap-8">
        <div class="cart-drawer__line-items">
          {%- for line_item in cart.items -%}
            {%- render 'line-item', line_item: line_item, show_desktop_quantity: true -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.products.count > 0 -%}
          <div class="cart-drawer__recommendations">
            <!-- Contenu des recommandations inchangé -->
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="v-stack gap-3 sm:gap-4" slot="footer" style="padding-top: 0;"> <!-- Espacement réduit -->
      <div class="v-stack gap-1">
        {% for discount_application in cart.cart_level_discount_applications %}
          <div class="h-stack gap-4 justify-between">
            <div class="badge">
              {%- render 'icon' with 'discount' -%} {{- discount_application.title -}}
            </div>
            <span class="text-subdued">-{{ discount_application.total_allocated_amount | money }}</span>
          </div>
        {% endfor %}

        <div class="h-stack gap-4 justify-between" style="margin-top: 8px;"> <!-- Espacement réduit -->
          <span class="h5">{{ 'cart.general.total' | t }}</span>
          <span class="h5">{{- cart.total_price | money_with_currency -}}</span>
        </div>
      </div>

      <form action="{{ routes.cart_url }}" method="POST" class="buy-buttons">
        {%- render 'button', 
          type: 'submit', 
          content: section.settings.checkout_button_text,  <!-- Texte personnalisé -->
          icon: 'picto-lock', 
          name: 'checkout', 
          size: 'xl',
          full_width: true 
        -%}
      </form>
      
      <!-- Logos de paiement et garantie -->
      <p style="text-align: center; margin-top: 12px; font-size: 0.85em; line-height: 1.3;"> <!-- Espacement ajusté -->
        🔒 Retours sans risque pendant 30 jours | Assistance 24h/24 et 7j/7
      </p>
    </div>
  {%- endif -%}
</cart-drawer>

<style>
  .cart-drawer {
    box-shadow: none !important;
  }

  .buy-buttons {
    width: 100%;
    margin-top: 12px; /* Espacement réduit */
  }

  .payment-icons-wrapper {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px; /* Espacement réduit */
  }
  
  .payment-icon img {
    width: 40px;
    height: 25px;
    object-fit: contain;
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }
  
  .payment-icon:hover img {
    opacity: 1;
  }
</style>

{% schema %}
{
  "name": "Cart drawer",
  "settings": [
    {
      "type": "header",
      "content": "Bouton de commande"
    },
    {
      "type": "text",
      "id": "checkout_button_text",
      "label": "Texte du bouton",
      "default": "Passer la commande"
    },
    {
      "type": "header",
      "content": "Product recommendations"
    },
    {
      "type": "text",
      "id": "recommendations_title",
      "label": "Heading",
      "default": "Trending this month"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Recommendations",
      "info": "Suggest additional products to your customers.",
      "limit": 10
    },
    {
      "type": "color",
      "id": "product_card_background",
      "label": "Product card background"
    },
    {
      "type": "color",
      "id": "product_card_text_color",
      "label": "Product card text"
    }
  ]
}
{% endschema %}