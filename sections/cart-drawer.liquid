<cart-drawer {% if request.design_mode %}handle-section-events{% endif %} class="cart-drawer drawer drawer--lg" id="cart-drawer">
  {%- if cart.item_count == 0 -%}
    <!-- Contenu du panier vide inchangé -->
  {%- else -%}
    <div>
      <div class="cart-drawer__top">
        <!-- Section Liquid ajoutée dans l'en-tête -->
        {%- if section.settings.header_liquid != blank -%}
          <div class="header-liquid-section">
            {{ section.settings.header_liquid }}
          </div>
        {%- endif -%}

        <div class="h-stack items-center justify-between">
          <div class="h-stack grow gap-2 sm:gap-2.5">
            <p class="h5">{{- 'cart.general.title' | t -}}</p>
            <cart-count class="count-bubble count-bubble--md">{{ cart.item_count }}</cart-count>
          </div>

          <button type="button" is="close-button" class="drawer__close-icon">
            <span class="sr-only">{{ 'general.accessibility.close' | t }}</span>
            {%- render 'icon' with 'close' -%}
          </button>
        </div>

        {%- if settings.cart_show_free_shipping_threshold -%}
          {%- render 'free-shipping-bar' -%}
        {%- endif -%}
      </div>

      <div class="v-stack gap-6 sm:gap-8">
        <!-- Contenu des articles inchangé -->
      </div>
    </div>

    <div class="v-stack gap-4 sm:gap-6" slot="footer">
      <div class="v-stack gap-1">
        <!-- Suppression des textes sur les taxes et notes -->
        <div class="h-stack gap-4 justify-between">
          <span class="h5">{{ 'cart.general.total' | t }}</span>
          <span class="h5">{{- cart.total_price | money_with_currency -}}</span>
        </div>
      </div>

      <form action="{{ routes.cart_url }}" method="POST" class="buy-buttons">
        <!-- Bouton checkout en pleine largeur -->
        {%- render 'button', 
          type: 'submit', 
          content: section.settings.checkout_button_text,
          custom_color: section.settings.checkout_button_color,
          name: 'checkout', 
          size: 'xl',
          full_width: true 
        -%}
      </form>
      
      <!-- Logos de paiement et garantie -->
      <p style="text-align: center; margin-top: 10px; font-size: 0.9em;"> 🔒 Retours sans risque pendant 30 jours | Assistance 24h/24 et 7j/7</p>
    </div>
  {%- endif -%}
</cart-drawer>

<style>
  .cart-drawer {
    box-shadow: none !important;
  }
  
  .header-liquid-section {
    margin-bottom: 15px;
  }

  .buy-buttons {
    width: 100%;
  }

  .payment-icons-wrapper {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 15px;
  }
  
  .payment-icon img {
    width: 40px;
    height: 25px;
    object-fit: contain;
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }
  
  .payment-icon:hover img {
    opacity: 1;
  }
</style>

{% schema %}
{
  "name": "Cart drawer",
  "settings": [
    {
      "type": "header",
      "content": "En-tête personnalisé"
    },
    {
      "type": "liquid",
      "id": "header_liquid",
      "label": "Section Liquid",
      "info": "Ajoutez du code Liquid personnalisé pour l'en-tête"
    },
    {
      "type": "header",
      "content": "Bouton de commande"
    },
    {
      "type": "text",
      "id": "checkout_button_text",
      "label": "Texte du bouton",
      "default": "Passer la commande"
    },
    {
      "type": "color",
      "id": "checkout_button_color",
      "label": "Couleur du bouton",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Recommandations produits"
    },
    {
      "type": "text",
      "id": "recommendations_title",
      "label": "Titre",
      "default": "Trending this month"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Produits recommandés",
      "limit": 10
    }
  ]
}
{% endschema %}