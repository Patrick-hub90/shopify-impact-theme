{%- if section.blocks.size > 0 -%}
  {%- render 'section-spacing-collapsing' -%}

  <style>
    #shopify-section-{{ section.id }} {
      --section-spacing-inline: 0;
      --scrolling-text-font-size: {% if section.settings.text_size == 'xsmall' %}1.125rem{% elsif section.settings.text_size == 'small' %}2.5rem{% elsif section.settings.text_size == 'medium' %}3.75rem{% elsif section.settings.text_size == 'large' %}5rem{% else %}7.5rem{% endif %};
    }

    @media screen and (min-width: 700px) {
      #shopify-section-{{ section.id }} {
        --scrolling-text-font-size: {% if section.settings.text_size == 'xsmall' %}1.5rem{% elsif section.settings.text_size == 'small' %}3.75rem{% elsif section.settings.text_size == 'medium' %}5rem{% elsif section.settings.text_size == 'large' %}8.75rem{% else %}12.5rem{% endif %};
      }
    }

    .scrolling-text__item {
      display: inline-flex;
      align-items: center;
      padding: 0 2rem;
      white-space: nowrap;
    }

    .scrolling-text__logo {
      display: flex;
      align-items: center;
      height: calc(var(--scrolling-text-font-size) * 1.2);
    }

    .scrolling-text__logo img {
      height: 100%;
      width: auto;
      max-width: 200px;
      object-fit: contain;
    }
  </style>

  {%- if section.settings.text_size == 'xsmall' -%}
    {%- assign is_tight = true -%}
  {%- endif -%}

  <div {% render 'section-properties', tight: is_tight %}>
    {%- capture section_content -%}
      {%- for block in section.blocks -%}
        <span class="scrolling-text__item">
          {%- case block.type -%}
            {%- when 'text' -%}
              <span class="scrolling-text__text heading">
                {%- render 'styled-text', content: block.settings.text, gradient: section.settings.text_gradient, style: block.settings.text_style -%}
              </span>
            
            {%- when 'logo' -%}
              <div class="scrolling-text__logo">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 400 | image_tag: 
                    loading: 'lazy', 
                    alt: block.settings.image.alt | escape 
                  }}
                {%- endif -%}
              </div>
          {%- endcase -%}
        </span>
      {%- endfor -%}
    {%- endcapture -%}

    <div class="scrolling-text scrolling-text--auto">
      <marquee-text scrolling-speed="{{ section.settings.scrolling_speed }}" class="scrolling-text__wrapper">
        {%- for i in (1..10) -%}
          <span class="announcement-bar__item" {% unless forloop.first %}aria-hidden="true"{% endunless %}>
            {{- section_content -}}
          </span>
        {%- endfor -%}
      </marquee-text>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Scrolling bandeau",
  "class": "shopify-section--scrolling-text",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Pleine largeur",
      "default": true
    },
    {
      "type": "select",
      "id": "text_size",
      "label": "Taille du texte",
      "options": [
        {
          "value": "xsmall",
          "label": "Très petit"
        },
        {
          "value": "small",
          "label": "Petit"
        },
        {
          "value": "medium",
          "label": "Moyen"
        },
        {
          "value": "large",
          "label": "Grand"
        },
        {
          "value": "xlarge",
          "label": "Très grand"
        }
      ],
      "default": "large"
    },
    {
      "type": "range",
      "id": "scrolling_speed",
      "min": 3,
      "max": 20,
      "step": 1,
      "unit": "s",
      "label": "Vitesse de défilement",
      "default": 10
    },
    {
      "type": "header",
      "content": "Couleurs",
      "info": "Le dégradé remplace les couleurs unies lorsqu'il est défini."
    },
    {
      "type": "color",
      "id": "background",
      "label": "Arrière-plan"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Dégradé d'arrière-plan"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texte"
    },
    {
      "type": "color_background",
      "id": "text_gradient",
      "label": "Dégradé de texte"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Texte",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "Promotion"
        },
        {
          "type": "select",
          "id": "text_style",
          "label": "Style de texte",
          "options": [
            {
              "value": "outline",
              "label": "Contour"
            },
            {
              "value": "fill",
              "label": "Rempli"
            }
          ],
          "default": "fill"
        }
      ]
    },
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Utilisez une image avec fond transparent pour de meilleurs résultats"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bandeau défilant",
      "blocks": [
        {
          "type": "text",
          "settings": {
            "text": "Nouvelle collection"
          }
        },
        {
          "type": "text",
          "settings": {
            "text": "• SOLDE •"
          }
        },
        {
          "type": "logo",
          "settings": {}
        },
        {
          "type": "text",
          "settings": {
            "text": "Livraison gratuite"
          }
        }
      ]
    }
  ]
}
{% endschema %}