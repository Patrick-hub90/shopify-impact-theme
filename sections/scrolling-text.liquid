{%- style -%}
  #shopify-section-{{ section.id }} .marquee-slider {
    padding: 45px 0;
    background-color: {{ section.settings.bg_color }};
  }

  #shopify-section-{{ section.id }} .marquee-slider ul.marquee-slider-list {
    transition-timing-function: linear !important;
    position: relative;
    margin: 0;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .marquee-slider li.swiper-slide {
    text-align: center;
    font-size: {{ section.settings.font_size }}px;
    line-height: 1.5;
    color: {{ section.settings.text_color }};
    font-weight: 500;
    display: flex;
    justify-content: center;
    align-items: center;
    width: auto;
    position: relative;
    overflow: hidden;
    list-style-type: none;
    margin-right: {{ section.settings.item_spacing }}px;
  }

  @media(max-width:749px) {
    #shopify-section-{{ section.id }} .marquee-slider {
      padding: 18px 0;
    }
    #shopify-section-{{ section.id }} .marquee-slider li.swiper-slide {
      font-size: {{ section.settings.mobile_font_size }}px;
    }
  }
{%- endstyle -%}

<div class="shopify-section marquee-slider marquee-{{ section.id }}">
  <div class="marquee-slider-body">
    <div class="marquee-slider-slider swiper">
      <ul class="marquee-slider-list swiper-wrapper" aria-live="off">
        {%- for block in section.blocks -%}
          <li class="swiper-slide" role="group" aria-label="{{ forloop.index }} / {{ section.blocks.size }}">
            <span>{{ block.settings.text }}</span>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  if (typeof Swiper !== 'undefined') {
    new Swiper('#shopify-section-{{ section.id }} .marquee-slider-slider', {
      spaceBetween: {{ section.settings.item_spacing }},
      centeredSlides: true,
      speed: {{ section.settings.speed }},
      autoplay: {
        delay: 1,
        reverseDirection: false
      },
      loop: true,
      loopedSlides: {{ section.blocks.size }},
      slidesPerView: 'auto',
      allowTouchMove: false,
      disableOnInteraction: true,
      breakpoints: {
        749: {
          spaceBetween: {{ section.settings.desktop_item_spacing }}
        }
      }
    });
  }
});
</script>

{% schema %}
{
  "name": "Marquee Slider",
  "settings": [
    {
      "type": "header",
      "content": "Design Options"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdd5d5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Desktop Font Size",
      "default": 18
    },
    {
      "type": "range",
      "id": "mobile_font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Mobile Font Size",
      "default": 13
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 100,
      "max": 1000,
      "step": 50,
      "unit": "ms",
      "label": "Animation Speed",
      "default": 500
    },
    {
      "type": "range",
      "id": "item_spacing",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Mobile Item Spacing",
      "default": 40
    },
    {
      "type": "range",
      "id": "desktop_item_spacing",
      "min": 40,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Desktop Item Spacing",
      "default": 70
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Slide Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "💡 Utilise la thérapie par lumière rouge, chaleur et aspiration"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Slider",
      "category": "Custom",
      "blocks": [
        {
          "type": "text",
          "settings": {
            "text": "🔬 Développé avec des techniques soutenues par la science"
          }
        },
        {
          "type": "text",
          "settings": {
            "text": "💡 Utilise la thérapie par lumière rouge, chaleur et aspiration"
          }
        },
        {
          "type": "text",
          "settings": {
            "text": "🩹 Technologie douce et sans ecchymoses"
          }
        }
      ]
    }
  ]
}
{% endschema %}