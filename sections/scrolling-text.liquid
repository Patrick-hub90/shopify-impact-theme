{%- style %}
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding }}px 0;
    overflow: hidden;
  }
  .scrolling-text__container {
    display: flex;
    width: max-content;
    animation: scroll {{ section.settings.speed }}s linear infinite;
  }
  .scrolling-text__item {
    flex-shrink: 0;
    padding: 0 {{ section.settings.spacing }}px;
    font-size: {{ section.settings.font_size }}px;
    color: {{ section.settings.text_color }};
    font-weight: {{ section.settings.font_weight }};
  }
  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
{% endstyle %}

<div class="scrolling-text">
  <div class="scrolling-text__wrapper">
    <div class="scrolling-text__container" style="--duplicates: {{ section.blocks.size }}">
      <!-- Premier passage des blocs -->
      {% for block in section.blocks %}
        <div class="scrolling-text__item" {{ block.shopify_attributes }}>
          {{ block.settings.text }}
        </div>
      {% endfor %}
      
      <!-- Duplication pour l'effet continu -->
      {% for block in section.blocks %}
        <div class="scrolling-text__item">
          {{ block.settings.text }}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const container = document.querySelector('.scrolling-text__container');
  
  // Calcul dynamique de la largeur pour l'animation
  function initAnimation() {
    if (!container) return;
    
    const firstItem = container.querySelector('.scrolling-text__item');
    if (!firstItem) return;
    
    const itemWidth = firstItem.offsetWidth + parseInt(getComputedStyle(firstItem).paddingLeft) * 2;
    container.style.setProperty('--item-width', `${itemWidth * section.blocks.length}px`);
  }
  
  // Redimensionnement adaptatif
  window.addEventListener('resize', initAnimation);
  initAnimation();
});
</script>

{% schema %}
{
  "name": "Texte Défilant",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de fond",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 5,
      "max": 100,
      "step": 5,
      "unit": "s",
      "label": "Vitesse de défilement",
      "default": 20
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Taille du texte",
      "default": 24
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Espacement entre textes",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding",
      "min": 5,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Marge verticale",
      "default": 15
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Épaisseur du texte",
      "options": [
        {"value": "400", "label": "Normal"},
        {"value": "700", "label": "Gras"}
      ],
      "default": "400"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Texte",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Contenu",
          "default": "Promotion spéciale • Livraison gratuite • Nouveautés"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Texte Défilant",
      "category": "Promotionnel"
    }
  ]
}
{% endschema %}