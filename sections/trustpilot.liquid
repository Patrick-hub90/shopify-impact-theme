{% style %}
/* Styles généraux */
.product-reviews-section {
  background-color: #ffffff;
  padding: 40px 20px;
  font-family: Helvetica, Arial, sans-serif;
}

/* En-tête Trustpilot */
.trustpilot-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 16px 0 30px;
}

.trustpilot-title {
  font-size: 15px;
  font-weight: 600;
  color: #000;
}

.trustpilot-subtitle {
  font-size: 13px;
  color: #888;
}

/* Carrousel */
.reviews-slider-wrapper {
  position: relative;
}

.reviews-slider {
  overflow: hidden;
}

.swiper-wrapper {
  display: flex;
  transition: transform 0.3s ease;
}

/* Carte d'avis */
.review-card {
  width: 228px;
  margin-right: 16px;
  background: #f9f9f9;
  border-radius: 8px;
  padding: 20px;
  box-sizing: border-box;
}

.review-stars {
  display: flex;
  gap: 3px;
  margin-bottom: 10px;
}

.review-stars img {
  width: 20px;
  height: 20px;
}

.review-verified {
  display: flex;
  align-items: center;
  gap: 5px;
  margin-bottom: 15px;
}

.review-verified svg {
  width: 16px;
  height: 16px;
}

.review-verified p {
  font-size: 13px;
  margin: 0;
}

.review-title {
  font-size: 16px;
  font-weight: 700;
  margin: 0 0 12px;
  line-height: 1.3;
}

.review-content {
  font-size: 14px;
  line-height: 1.5;
  color: #333;
  margin-bottom: 15px;
}

.review-meta {
  display: flex;
  gap: 5px;
  font-size: 13px;
  color: #666;
}

/* Navigation */
.slider-nav-btn {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  cursor: pointer;
  z-index: 10;
}

.slider-prev {
  left: -30px;
}

.slider-next {
  right: -30px;
}

/* Note globale */
.reviews-summary {
  text-align: center;
  margin-top: 30px;
  font-size: 14px;
}

/* Responsive */
@media (max-width: 768px) {
  .slider-nav-btn {
    display: none;
  }
  
  .reviews-slider-wrapper {
    overflow-x: auto;
    padding-bottom: 20px;
  }
  
  .swiper-wrapper {
    flex-wrap: nowrap;
  }
}
{% endstyle %}

<section class="product-reviews-section">
  <!-- En-tête Trustpilot -->
  <div class="trustpilot-header">
    <img src="https://cdn.trustpilot.net/brand-assets/4.0.0/logo-black.svg" alt="Trustpilot" style="height: 20px;">
    <div>
      <div class="trustpilot-title">Vérifié par Trustpilot</div>
      <div class="trustpilot-subtitle">Basé sur plus de 2000 avis clients vérifiés</div>
    </div>
  </div>

  <div class="reviews-slider-wrapper">
    <!-- Boutons de navigation -->
    <button class="slider-nav-btn slider-prev">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    
    <button class="slider-nav-btn slider-next">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>

    <!-- Conteneur des avis -->
    <div class="reviews-slider">
      <div class="swiper-wrapper">
        <!-- Avis 1 -->
        <div class="review-card">
          <div class="review-stars">
            {% for i in (1..5) %}
              <img src="//vaovac.com/cdn/shop/files/single-star-5.png?v=1747694033" alt="5 étoiles">
            {% endfor %}
          </div>
          
          <div class="review-verified">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><path fill="#000" fill-rule="evenodd" d="M1 12C1 5.92487 5.92487 1 12 1C18.0751 1 23 5.92487 23 12C23 18.0751 18.0751 23 12 23C5.92487 23 1 18.0751 1 12ZM11.2071 16.2071L18.2071 9.20711L16.7929 7.79289L10.5 14.0858L7.20711 10.7929L5.79289 12.2071L9.79289 16.2071C9.98043 16.3946 10.2348 16.5 10.5 16.5C10.7652 16.5 11.0196 16.3946 11.2071 16.2071Z" clip-rule="evenodd"></path></svg>
            <p>Vérifié</p>
          </div>
          
          <h2 class="review-title">8 semaines d'expérience</h2>
          
          <div class="review-content">
            <p>Je n'aurais jamais cru que quoi que ce soit puisse réduire l'apparence de la cellulite sur mes cuisses, mais Vaovac m'a prouvé le contraire...</p>
          </div>
          
          <div class="review-meta">
            <span class="review-author">Vérone,</span>
            <span class="review-date">01/02/2025</span>
          </div>
        </div>
        
        <!-- Ajoutez d'autres avis ici avec la même structure -->
        <!-- Avis 2 -->
        <div class="review-card">
          <!-- ... -->
        </div>
      </div>
    </div>
  </div>

  <!-- Note globale -->
  <div class="reviews-summary">
    <p>Note : <strong>4,8</strong> /5 selon 2028 avis. Nos avis 5 étoiles sont affichés.</p>
  </div>
</section>

<script>
// Script pour le carrousel
document.addEventListener('DOMContentLoaded', function() {
  const slider = document.querySelector('.reviews-slider');
  const wrapper = slider.querySelector('.swiper-wrapper');
  const cards = wrapper.querySelectorAll('.review-card');
  const prevBtn = document.querySelector('.slider-prev');
  const nextBtn = document.querySelector('.slider-next');
  
  let currentPosition = 0;
  const cardWidth = cards[0].offsetWidth + 16; // Largeur + marge
  
  function updateButtons() {
    prevBtn.disabled = currentPosition === 0;
    nextBtn.disabled = currentPosition <= -(cards.length * cardWidth - slider.offsetWidth);
  }
  
  prevBtn.addEventListener('click', () => {
    if (currentPosition < 0) {
      currentPosition += cardWidth * 3;
      wrapper.style.transform = `translateX(${currentPosition}px)`;
      updateButtons();
    }
  });
  
  nextBtn.addEventListener('click', () => {
    if (currentPosition > -(cardWidth * (cards.length - 3))) {
      currentPosition -= cardWidth * 3;
      wrapper.style.transform = `translateX(${currentPosition}px)`;
      updateButtons();
    }
  });
  
  // Initialisation
  updateButtons();
  
  // Redimensionnement de la fenêtre
  window.addEventListener('resize', updateButtons);
});
</script>