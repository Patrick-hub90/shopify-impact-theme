{%- if section.blocks.size > 0 -%}
  {%- render 'section-spacing-collapsing' -%}

  <style>
    #shopify-section-{{ section.id }} {
      --multi-column-grid: {% if section.settings.stack_on_mobile %}none{% else %}auto / auto-flow 73vw{% endif %};
      --multi-column-list-gap: {% if section.settings.gap == 'small' %}var(--grid-gutter){% elsif section.settings.gap == 'medium' %}var(--spacing-12){% elsif section.settings.gap == 'large' %}var(--spacing-20){% else %}var(--spacing-28){% endif %};
    }

    .expert-badge {
      background: {{ section.settings.badge_color }};
      color: {{ section.settings.badge_text_color }};
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
      display: inline-block;
      margin-top: 8px;
    }

    .doctor-rating {
      display: flex;
      gap: 2px;
      margin: 8px 0;
    }

    .star-full {
      color: #FFD700;
    }

    .star-empty {
      color: #e0e0e0;
    }
  </style>

  <div {% render 'section-properties' %}>
    <div class="section-stack">
      {%- render 'section-header', subheading: section.settings.subheading, heading: section.settings.title, content: section.settings.content, text_alignment: section.settings.text_alignment -%}

      <div class="multi-column scroll-area bleed md:unbleed">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'expert' -%}
              <div class="multi-column__item justify-{{ section.settings.text_alignment }} snap-start" style="--multi-column-item-column-count: span {{ 12.0 | divided_by: block.settings.column_size | round }}" {{ block.shopify_attributes }}>
                <div class="v-stack gap-6">
                  {%- if block.settings.image != blank -%}
                    {%- capture sizes -%}(max-width: 699px) calc(73vw - 40px), (max-width: 999px) calc(38vw - 64px), calc(min({{ settings.page_width }}px, 100vw) / {{ block.settings.column_size }}){%- endcapture -%}
                    <div class="rounded-full overflow-hidden" style="width: 120px; height: 120px; margin: 0 auto;">
                      {{- block.settings.image | image_url: width: 240 | image_tag: loading: 'lazy', sizes: sizes, widths: '120,240,360', class: 'object-cover w-full h-full' -}}
                    </div>
                  {%- endif -%}

                  <div class="v-stack gap-4 text-{{ section.settings.text_alignment }}">
                    {%- if block.settings.title != blank -%}
                      <p class="h4">{{ block.settings.title | escape }}</p>
                    {%- endif -%}

                    {%- if block.settings.specialty != blank -%}
                      <p class="text-sm text-subdued">{{ block.settings.specialty | escape }}</p>
                    {%- endif -%}

                    {%- if block.settings.hospital != blank -%}
                      <p class="text-xs">{{ block.settings.hospital | escape }}</p>
                    {%- endif -%}

                    <div class="expert-badge">EXPERT CERTIFIÉ</div>

                    {%- if block.settings.rating > 0 -%}
                      <div class="doctor-rating">
                        {%- for i in (1..5) -%}
                          {%- if i <= block.settings.rating -%}
                            <span class="star-full">★</span>
                          {%- else -%}
                            <span class="star-empty">★</span>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    {%- endif -%}

                    {%- if block.settings.content != blank -%}
                      <div class="prose">
                        <blockquote>{{ block.settings.content }}</blockquote>
                      </div>
                    {%- endif -%}

                    {%- if block.settings.link_text != blank -%}
                      <div>
                        <a href="{{ block.settings.link_url }}" class="link text-sm">
                          {{ block.settings.link_text | escape }}
                        </a>
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Avis Expert Médical",
  "class": "shopify-section--medical-experts",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Pleine largeur",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "stack_on_mobile",
      "label": "Empiler sur mobile",
      "default": false
    },
    {
      "type": "select",
      "id": "gap",
      "label": "Espacement",
      "options": [
        {
          "value": "small",
          "label": "Petit"
        },
        {
          "value": "medium",
          "label": "Moyen"
        },
        {
          "value": "large",
          "label": "Grand"
        },
        {
          "value": "x-large",
          "label": "Très grand"
        }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alignement du texte",
      "options": [
        {
          "value": "start",
          "label": "Gauche"
        },
        {
          "value": "center",
          "label": "Centre"
        },
        {
          "value": "end",
          "label": "Droite"
        }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Expertise médicale"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Avis de nos experts"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Description",
      "default": "<p>Nos médecins spécialistes partagent leur expertise</p>"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Couleur du badge",
      "default": "#0D9488"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Couleur texte badge",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Arrière-plan",
      "default": "#F9FAFB"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texte",
      "default": "#1F2937"
    }
  ],
  "blocks": [
    {
      "type": "expert",
      "name": "Expert Médical",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo du docteur",
          "info": "Format portrait recommandé"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Nom du docteur",
          "default": "Dr. Sophie Martin"
        },
        {
          "type": "text",
          "id": "specialty",
          "label": "Spécialité",
          "default": "Cardiologue"
        },
        {
          "type": "text",
          "id": "hospital",
          "label": "Établissement",
          "default": "Hôpital Saint-Louis, Paris"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Note (étoiles)",
          "min": 0,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Avis",
          "default": "<p>Ce produit représente une avancée significative dans son domaine. Je le recommande à mes patients pour son efficacité et sa sécurité d'utilisation.</p>"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Texte du lien",
          "default": "Voir le profil complet"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Lien"
        },
        {
          "type": "select",
          "id": "column_size",
          "label": "Largeur colonne",
          "options": [
            {
              "value": "4",
              "label": "25%"
            },
            {
              "value": "3",
              "label": "33%"
            },
            {
              "value": "2",
              "label": "50%"
            }
          ],
          "default": "3"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Avis Expert Médical",
      "blocks": [
        {
          "type": "expert",
          "settings": {
            "title": "Dr. Jean Dupont",
            "specialty": "Dermatologue",
            "hospital": "CHU de Bordeaux",
            "content": "<p>Formulation exceptionnelle pour les peaux sensibles. Résultats cliniques très convaincants après 4 semaines d'utilisation.</p>"
          }
        },
        {
          "type": "expert",
          "settings": {
            "title": "Dr. Marie Legrand",
            "specialty": "Pédiatre",
            "hospital": "Hôpital Necker, Paris",
            "content": "<p>Produit adapté aux enfants, testé sous contrôle médical. Absence d'effets secondaires notables dans notre étude.</p>"
          }
        },
        {
          "type": "expert",
          "settings": {
            "title": "Pr. Alain Petit",
            "specialty": "Neurologue",
            "hospital": "CHU de Lyon",
            "content": "<p>Innovation remarquable dans le traitement des migraines chroniques. Efficacité démontrée dans 85% des cas.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}