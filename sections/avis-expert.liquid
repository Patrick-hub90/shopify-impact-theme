{% comment %}
  Section: Expert Reviews Carousel
  Description: Affiche des avis d'experts sous forme de carrousel ou de grille
{% endcomment %}

{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>

<style>
  .expert-reviews-section {
    max-width: 1200px;
    margin: 60px auto;
    padding: 0 20px;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }
  
  .section-header {
    text-align: {{ section.settings.text_alignment }};
    margin-bottom: 50px;
  }
  
  .section-header .subheading {
    font-size: 18px;
    color: #666;
    margin-bottom: 10px;
    display: block;
  }
  
  .section-header h2 {
    font-size: 32px;
    color: #333;
    margin-bottom: 15px;
    position: relative;
    display: inline-block;
  }
  
  .section-header .description {
    font-size: 18px;
    color: #555;
    line-height: 1.6;
    max-width: 800px;
    margin: 20px auto 0;
  }
  
  .reviews-container {
    position: relative;
    padding: 20px 0;
  }
  
  .swiper {
    padding: 30px 10px 60px;
  }
  
  .review-card {
    background: white;
    border-radius: 15px;
    overflow: hidden;
    border: 1px solid #f0f0f0;
    transition: all 0.4s ease;
    height: auto;
    display: flex;
    flex-direction: column;
  }
  
  .review-image {
    height: 250px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #fff5f7 0%, #f8f9fa 100%);
  }
  
  .review-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  .review-content {
    padding: 30px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  
  .review-text {
    font-size: 16px;
    line-height: 1.7;
    color: #555;
    margin-bottom: 25px;
    flex-grow: 1;
  }
  
  .review-text strong {
    color: #ff6b6b;
    font-weight: 600;
  }
  
  .review-author {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-top: auto;
  }
  
  .signature {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff5f7;
    border-radius: 50%;
    padding: 5px;
  }
  
  .signature img {
    width: 24px;
    height: 24px;
  }
  
  .author-info h4 {
    font-size: 18px;
    color: #333;
    margin: 0 0 5px 0;
  }
  
  .author-info p {
    font-size: 14px;
    color: #666;
    margin: 0;
  }
  
  .swiper-button-prev,
  .swiper-button-next {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: white;
    border: 1px solid #ddd;
    color: {{ section.settings.arrow_color }};
    transition: all 0.3s ease;
  }
  
  .swiper-button-prev:after,
  .swiper-button-next:after {
    font-size: 18px;
    font-weight: bold;
  }
  
  .swiper-button-prev:hover,
  .swiper-button-next:hover {
    background: {{ section.settings.arrow_color }};
    color: white;
    border-color: {{ section.settings.arrow_color }};
  }
  
  .swiper-pagination-bullet {
    width: 12px;
    height: 12px;
    background: #ddd;
    opacity: 1;
  }
  
  .swiper-pagination-bullet-active {
    background: {{ section.settings.arrow_color }};
  }

  /* Stack mode */
  .reviews-stack {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  @media (max-width: 1024px) {
    .reviews-stack {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .reviews-stack {
      grid-template-columns: 1fr;
    }
    
    .section-header h2 {
      font-size: 26px;
    }
    
    .swiper {
      padding: 30px 0 60px;
    }
    
    .swiper-button-prev,
    .swiper-button-next {
      display: none;
    }
  }
</style>

<div class="expert-reviews-section" data-stack-mode="{{ section.settings.stack_on_mobile }}">
  <div class="section-header">
    {%- if section.settings.subheading != blank -%}
      <span class="subheading">{{ section.settings.subheading }}</span>
    {%- endif -%}
    
    <h2>{{ section.settings.section_title }}</h2>
    
    {%- if section.settings.description != blank -%}
      <div class="description">{{ section.settings.description }}</div>
    {%- endif -%}
  </div>
  
  <div class="reviews-container">
    {% if section.settings.stack_on_mobile %}
      <!-- Mode Stack (grille) -->
      <div class="reviews-stack">
        {% for block in section.blocks %}
          <div class="review-card">
            <div class="review-image">
              {% if block.settings.doctor_image %}
                <img src="{{ block.settings.doctor_image | img_url: '600x600' }}" 
                     alt="{{ block.settings.doctor_name }}" 
                     loading="lazy">
              {% else %}
                <div style="background: #f0f0f0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #999;">
                  Image de l'expert
                </div>
              {% endif %}
            </div>
            
            <div class="review-content">
              <div class="review-text">
                {{ block.settings.review_text }}
              </div>
              
              <div class="review-author">
                {% if block.settings.signature_image %}
                  <div class="signature">
                    <img src="{{ block.settings.signature_image | img_url: '100x100' }}" 
                         alt="Signature" 
                         loading="lazy">
                  </div>
                {% endif %}
                
                <div class="author-info">
                  <h4>{{ block.settings.doctor_name }}</h4>
                  <p>{{ block.settings.doctor_specialty }}</p>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <!-- Mode Carrousel -->
      <div class="swiper">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide">
              <div class="review-card">
                <div class="review-image">
                  {% if block.settings.doctor_image %}
                    <img src="{{ block.settings.doctor_image | img_url: '600x600' }}" 
                         alt="{{ block.settings.doctor_name }}" 
                         loading="lazy">
                  {% else %}
                    <div style="background: #f0f0f0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #999;">
                      Image de l'expert
                    </div>
                  {% endif %}
                </div>
                
                <div class="review-content">
                  <div class="review-text">
                    {{ block.settings.review_text }}
                  </div>
                  
                  <div class="review-author">
                    {% if block.settings.signature_image %}
                      <div class="signature">
                        <img src="{{ block.settings.signature_image | img_url: '100x100' }}" 
                             alt="Signature" 
                             loading="lazy">
                      </div>
                    {% endif %}
                    
                    <div class="author-info">
                      <h4>{{ block.settings.doctor_name }}</h4>
                      <p>{{ block.settings.doctor_specialty }}</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
        
        <div class="swiper-pagination"></div>
        <div class="swiper-button-prev"></div>
        <div class="swiper-button-next"></div>
      </div>
    {% endif %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('.expert-reviews-section');
    const stackMode = section.dataset.stackMode === 'true';
    
    if (!stackMode) {
      const swiper = new Swiper('.swiper', {
        loop: true,
        slidesPerView: 1,
        spaceBetween: 30,
        autoplay: {
          delay: 5000,
          disableOnInteraction: false,
        },
        pagination: {
          el: '.swiper-pagination',
          clickable: true,
        },
        navigation: {
          nextEl: '.swiper-button-next',
          prevEl: '.swiper-button-prev',
        },
        breakpoints: {
          640: {
            slidesPerView: 2,
            spaceBetween: 20
          },
          1024: {
            slidesPerView: 3,
            spaceBetween: 30
          }
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Avis d'Experts",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Témoignages"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Titre",
      "default": "Ce que disent les experts à propos de SheVitality"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Découvrez ce que les professionnels de santé pensent de nos produits</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alignement du texte",
      "options": [
        {
          "value": "left",
          "label": "Gauche"
        },
        {
          "value": "center",
          "label": "Centre"
        },
        {
          "value": "right",
          "label": "Droite"
        }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "stack_on_mobile",
      "label": "Empiler verticalement sur mobile",
      "default": false,
      "info": "Désactivé = mode carrousel horizontal"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Couleur des flèches",
      "default": "#ff6b6b"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Avis d'expert",
      "settings": [
        {
          "type": "image_picker",
          "id": "doctor_image",
          "label": "Photo du docteur"
        },
        {
          "type": "richtext",
          "id": "review_text",
          "label": "Texte de l'avis",
          "default": "<p>En tant que dermatologue certifié avec plus de 15 ans d'expérience clinique, je recommande le <strong>kit de soulagement de la cellulite</strong> aux patients à la recherche de solutions efficaces à domicile contre la cellulite et le relâchement cutané.</p>"
        },
        {
          "type": "image_picker",
          "id": "signature_image",
          "label": "Image de signature"
        },
        {
          "type": "text",
          "id": "doctor_name",
          "label": "Nom du docteur",
          "default": "Dr Emily Shaffer, MD, PhD"
        },
        {
          "type": "text",
          "id": "doctor_specialty",
          "label": "Spécialité",
          "default": "Dermatologue spécialiste agréé"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Avis d'Experts",
      "category": "Contenu"
    }
  ]
}
{% endschema %}